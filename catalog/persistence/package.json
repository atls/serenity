{
  "name": "@catalog/persistence",
  "version": "0.1.1",
  "license": "BSD-3-Clause",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "migration:generate": "yarn run typeorm migration:generate",
    "migration:run": "yarn typeorm migration:run --dataSource=./src/ormconfig.ts",
    "typeorm": "TS_NODE_PROJECT=./tsconfig.json node --loader ts-node/esm $(yarn bin typeorm)"
  },
  "dependencies": {
    "@catalog/domain": "workspace:*",
    "@godaddy/terminus": "4.12.1",
    "@monstrs/nestjs-logger": "0.4.6",
    "@nestjs/typeorm": "11.0.0",
    "@node-ts/ddd": "0.2.0",
    "@node-ts/ddd-types": "0.2.0",
    "pg": "8.13.3",
    "ts-node": "10.9.2",
    "typeorm": "0.3.21",
    "typescript": "5.5.4"
  },
  "devDependencies": {
    "@nestjs/common": "11.0.11",
    "@nestjs/core": "11.0.11",
    "@types/node": "22.13.8",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.21"
  },
  "peerDependencies": {
    "@nestjs/common": "*",
    "@nestjs/core": "*"
  },
  "skipLibCheck": true
}
